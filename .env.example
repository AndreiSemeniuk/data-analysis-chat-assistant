# --- LLM provider -----------------------------------------------------------
# Primary: Google Gemini (get a free key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key
MODEL_NAME=gemini-2.5-flash

# Optional fallback provider used automatically when Gemini is down / rate-limited.
# Leave empty to disable the fallback.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Database ----------------------------------------------------------------
# "bigquery"  -> live bigquery-public-data.thelook_ecommerce (needs GCP auth)
# "demo"      -> local DuckDB seeded with synthetic thelook-like data (no GCP needed)
DB_BACKEND=bigquery
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=bigquery-public-data.thelook_ecommerce
BQ_MAX_BYTES_BILLED=1073741824   # 1 GiB hard cap per query

# --- Agent -------------------------------------------------------------------
DEFAULT_USER=manager_a
MAX_SQL_ATTEMPTS=3               # 1 initial generation + 2 self-heal retries
MAX_LLM_CALLS_PER_TURN=8         # circuit breaker against runaway loops / cost
MAX_RESULT_ROWS=200

# --- Observability -----------------------------------------------------------
TRACE_FILE=logs/traces.jsonl
# Optional: full LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=...
